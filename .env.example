# ===============================================================
# Configuración SMTP para envío de correos
# ===============================================================
# IMPORTANTE: Copia este archivo a .env y configure con sus valores reales
# Para Gmail, necesita generar una "Contraseña de aplicación":
# https://myaccount.google.com/apppasswords
# ===============================================================

# Correo desde el cual se enviarán los correos
# Ejemplo: tu_correo@ieee.org
EMAIL_REMITENTE=tu_correo@ieee.org

# Contraseña de aplicación (NO usar la contraseña normal de Gmail)
# Para Gmail: https://myaccount.google.com/apppasswords
# Formato: xxxx xxxx xxxx xxxx (16 caracteres sin espacios en uso real)
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Configuración del servidor SMTP (por defecto Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Clave secreta de Flask (generar una string aleatoria fuerte para producción)
# Puede usar: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
